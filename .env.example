# =============================================================================
# SOP Software — environment template
# Copy to .env.local and fill in values. Never commit .env.local.
# =============================================================================

# --- Required ---
MONGODB_URI=mongodb://localhost:27017/sop-software

# --- Auth (required in production) ---
NEXTAUTH_SECRET=generate-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# --- Runtime LLM routing ---
# MCQ generation provider: claude | gemini | ollama (default: claude)
LLM_PROVIDER=claude
# Compliance provider: gemini | claude | codex | ollama (default: gemini)
LLM_COMPLIANCE_PROVIDER=gemini

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
COMPLIANCE_GEMINI_MODEL=
GEMINI_FREE_TIER=1
GEMINI_COMPLIANCE_MIN_GAP_MS=0

# --- Claude (MCQ + optional compliance) ---
# When set, MCQ uses Anthropic API directly (~10x faster than Claude Code CLI)
ANTHROPIC_API_KEY=
CLAUDE_CLI_MODEL=claude-sonnet-4-6
MCQ_CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_CLI_TIMEOUT_MS=300000
CLAUDE_CLI_MAX_ATTEMPTS=2

# --- Ollama (local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_COMPLIANCE_MODEL=
OLLAMA_TIMEOUT_MS=120000
OLLAMA_COMPLIANCE_TIMEOUT_MS=300000
OLLAMA_COMPLIANCE_MAX_TOKENS=8192
OLLAMA_NUM_CTX=32768

# --- Codex (MCQ via local CLI + ChatGPT subscription — no API key) ---
MCQ_CODEX_MODEL=gpt-5.4-mini
# Separate model for compliance analysis (heavier task — use smarter model)
COMPLIANCE_CODEX_MODEL=gpt-4.1
CODEX_CLI_TIMEOUT_MS=300000
CODEX_CLI_MAX_ATTEMPTS=2
MCQ_CLAUSES_PER_CALL_CODEX=5
MCQ_LEGACY_BATCH_CODEX=20
MCQ_CONTENT_LIMIT_CODEX=6000

# --- MCQ generation tuning ---
MCQ_FAST_FILL=1
MCQ_USE_CLAUSE_PHASE=0
# Fact-based pipeline for Codex (extract facts → one MCQ per fact → local dedup). Set 0 to disable.
MCQ_USE_FACT_PIPELINE=1
MCQ_FACTS_PER_BATCH_CODEX=15
MCQ_MAX_FACT_REPAIR_BATCHES=4
MCQ_CLAUSES_PER_CALL=15
MCQ_CLAUSES_PER_CALL_API=12
MCQ_CLAUSES_PER_CALL_CLI=5
MCQ_LEGACY_BATCH_API=40
MCQ_LEGACY_BATCH_CLI=15
MCQ_LEGACY_BATCH_GEMINI=25
MCQ_LEGACY_BATCH_OLLAMA=20
MCQ_MAX_LEGACY_BATCHES=8
MCQ_CONTENT_LIMIT_CLAUDE=6000

# --- Compliance tuning ---
COMPLIANCE_MAX_CLAUSES_PER_BATCH=40
COMPLIANCE_MAX_CLAUSES_DEEP_BATCH=20
COMPLIANCE_MAX_DEEP_GAP_CLAUSES=120
COMPLIANCE_SKIP_DEEP_ENRICHMENT=0
COMPLIANCE_BATCH_CONCURRENCY=8
COMPLIANCE_DEEP_BATCH_CONCURRENCY=6
# Full SOP chars sent during deep enrichment (confirmed gaps only)
COMPLIANCE_MAX_SOP_CHARS_PER_BATCH=55000
# Reduced SOP chars for fast screening pass — section map already included
# CLI providers (codex/claude): 8000; Gemini paid: 12000; Ollama: 2000
COMPLIANCE_MAX_SOP_CHARS_SCREEN=8000
COMPLIANCE_MAX_SECTION_SUMMARY_CHARS=8000
COMPLIANCE_MAX_CLAUSE_TEXT_CHARS=4000

# --- Bunny CDN (file storage) ---
BUNNY_STORAGE_PASSWORD=
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_HOSTNAME=
BUNNY_PULL_ZONE_URL=
BUNNY_CDN_URL=
BUNNY_UPLOAD_TIMEOUT_MS=120000
BUNNY_UPLOAD_MAX_RETRIES=3

# --- App ---
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
DOCX_VIEWER_SECRET=
